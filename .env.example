# Переменные окруже��ия для прокси-сборщика

# ===== HTTP Настройки =====
# Timeout для HTTP запросов (секунды)
REQUEST_TIMEOUT=25

# Timeout для проверки пинга прокси (секунды)
PING_TIMEOUT=5

# URL для тестирования доступности прокси
PING_URL=http://www.gstatic.com/generate_204

# ===== Кэширование =====
# Время жизни кэша (часы)
CACHE_TTL_HOURS=6

# ===== Параллелизм =====
# Количество одновременных потоков для загрузки/парсинга
MAX_WORKERS=5

# ===== Тестирование прокси =====
# Включить тестирование прокси по пингу (true/false)
TEST_PROXIES=false

# Количество прокси для выборочного тестирования (0 = все)
TEST_SAMPLE_SIZE=50

# ===== GitHub API =====
# GitHub personal access token (опционально, повышает лимит API)
# Получить: https://github.com/settings/tokens
# Нужны scopes: public_repo, read:org
GITHUB_TOKEN=

# ===== Примеры конфигураций папок =====
# Скрипт автоматически ищет эти папки в репозиториях:
# - config
# - configs
# - conf
# - configuration
